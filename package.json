{
  "name": "axontology",
  "version": "1.0.0",
  "description": "AxOntology - A Shared Brain for Humans and AI Agents",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:mcp": "node dist/mcpServer.js",
    "dev": "tsx watch src/index.ts < /dev/null",
    "dev:mcp": "tsx src/mcpServer.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "Amit Deshmukh",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "fastmcp": "^3.26.7",
    "graphql": "^16.12.0",
    "mercurius": "^16.6.0",
    "surrealdb": "^1.3.2",
    "surrealdb.js": "^1.0.0",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
